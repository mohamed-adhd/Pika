
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="live_message_app.App"
             xmlns:vm="using:live_message_app.ViewModels"
             xmlns:views="using:live_message_app.Views"
             xmlns:local="using:live_message_app"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
             
             
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
            
        </DataTemplate>
             
        
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:register/>
            
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
            <views:MainMenu/>
            
        </DataTemplate>
        
        
    </Application.DataTemplates>    
             
             
             
</Application>