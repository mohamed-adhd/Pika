<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.recover"
    x:DataType="vm:RecoverViewModel">
    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4F46E5"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#0B1020">

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#16213E"
                CornerRadius="16"
                Padding="40,36"
                Width="360">
            <StackPanel Spacing="0">

                <Border Width="48" Height="48"
                        CornerRadius="24"
                        Background="#1A2744"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="🔑"
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Forgot password?"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="we'll send you password info to your gmail"
                           FontSize="13"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,4,0,28"/>

                <Border IsVisible="{Binding Info, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="#0D1829"
                        BorderBrush="#1A2744"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,0,0,16">
                    <TextBlock Text="{Binding Info}"
                               Foreground="#94A3B8"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="Username"
                           Foreground="#94A3B8"
                           FontSize="12"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding R_username}"
                         PlaceholderText="@username"
                         Background="#0D1829"
                         BorderBrush="#1A2744"
                         CornerRadius="8"
                         Padding="12,10"
                         Margin="0,0,0,24"/>

                <Button Classes="primary"
                        Content="Send recovery email"
                        Command="{Binding SendRecoveryCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#6366F1"
                        Foreground="White"
                        CornerRadius="8"
                        Padding="0,11"
                        FontSize="14"
                        FontWeight="Medium"/>

                <Button Content="back to sign in"
                        Command="{Binding GoToLoginCommand}"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        Foreground="#64748B"
                        FontSize="12"
                        Margin="0,16,0,0"/>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>