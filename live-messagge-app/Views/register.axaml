<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.register"
    x:DataType="vm:RegisterViewModel">
    <Grid >
        <Button HorizontalAlignment="Left" VerticalAlignment="Top" Content="go to login" Command="{Binding GoToLoginCommand}"/>
        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Bottom" Text="{Binding Message}"></TextBlock>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBox Text="{Binding Name}" PlaceholderText="name" Background="DarkGray"></TextBox>
            <TextBox Text="{Binding Username}" PlaceholderText="username" Background="DarkGray"></TextBox>
            <TextBox Text="{Binding Passwrd}" PlaceholderText="password" Background="DarkGray"></TextBox>
            <TextBox Text="{Binding Cpasswd}" PlaceholderText="confirm password" Background="DarkGray"></TextBox>
            <TextBox Text="{Binding Gmail}" PlaceholderText="gmail" Background="DarkGray"></TextBox>
            <Button Content="register" Command="{Binding registerCommand}"></Button>
        </StackPanel>
    </Grid>
</UserControl>

