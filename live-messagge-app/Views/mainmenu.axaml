<UserControl
    
    xmlns:services="using:live_message_app.Services"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.MainMenu"
    x:DataType="vm:MainMenuViewModel">
    <UserControl.Styles>
        <Style Selector="Border.convo-item:pointerover">
            <Setter Property="Background" Value="#1A2744"/>
        </Style>
    </UserControl.Styles>
    <Grid>
        <!-- ain't gon lie , ts became easier than i thought, jsut some javascript and some html lmao-->
        <Grid ColumnDefinitions="280,*">
            <Border Grid.Column="0" Background="#16213E">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Grid Grid.Row="0" Margin="12,12,12,8" ColumnDefinitions="*,Auto,Auto">
            <TextBlock Grid.Column="0" Text="messages" FontSize="16" FontWeight="Medium"></TextBlock>
            <Button Grid.Column="1" Width="32" Height="32" CornerRadius="8" Background="#1A2744" Command="{Binding open_inviteCommand}" Content="+"/>
            <Button Grid.Column="2" Width="32" Height="32" CornerRadius="8" Background="#1A2744" Command="{Binding open_settingCommand}" Content="⚙"/>
            </Grid>
                    <TextBox Grid.Row="1" Margin="12,0,12,8" PlaceholderText="Search..." Background="#0D1829" CornerRadius="8" Padding="10,8"/>
                    <ScrollViewer Grid.Row="2" >
                        <ListBox Background ="#0D1829" ItemsSource="{Binding Flist}"
                                 SelectedItem="{Binding SelectedUser}">

                            <ListBox.Styles>

                                <Style Selector="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Stretch"/>
                                    <Setter Property="Padding"
                                            Value="0"/>
                                    <Setter Property="Margin"
                                            Value="2"/>
                                </Style>

                                <Style Selector="ListBoxItem:pointerover /template/ Border#ChatBorder">
                                    <Setter Property="Background" Value="#1A2744"/>
                                </Style>

                                <Style Selector="ListBoxItem:selected /template/ Border#ChatBorder">
                                    <Setter Property="Background" Value="#274B7A"/>
                                </Style>

                            </ListBox.Styles>

                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="services:user">

                                    <Border x:Name="ChatBorder"
                                            Background="Transparent"
                                            CornerRadius="8"
                                            Padding="8">

                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="10">

                                            <Ellipse Width="40"
                                                     Height="40"
                                                     Fill="Gray"/>

                                            <StackPanel VerticalAlignment="Center">

                                                <TextBlock Text="{Binding username}"
                                                           FontSize="16"
                                                           FontWeight="Bold"/>

                                                <TextBlock Text="{Binding LastMessage}"
                                                           FontSize="12"
                                                           Opacity="0.7"/>

                                            </StackPanel>

                                        </StackPanel>

                                    </Border>

                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                        
                    </ScrollViewer>
                    <Grid Grid.Row="3" Margin="12,8" ColumnDefinitions="Auto,*,Auto"></Grid>
                </Grid>
            </Border>
                            
                <Grid Grid.Column="1"
                      RowDefinitions="Auto,*,Auto"
                      Background="#0B1020">

                 
                    <Border Grid.Row="0"
                            Background="#10182B"
                            Padding="18,10"
                            BorderBrush="#1A2744"
                            BorderThickness="0,0,0,1">

                        <TextBlock Text="{Binding SelectedUser.username}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>



                    <ScrollViewer x:Name="Scrollshi"
                                  Grid.Row="1"
                                  Padding="0"
                                  VerticalScrollBarVisibility="Auto">

                        <ItemsControl ItemsSource="{Binding SelectedMessages}">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:Messagestruct">

                                    <Border Background="#1A2744"
                                            CornerRadius="14"
                                            Padding="12,8"
                                            Margin="0,4,0,4"
                                            MaxWidth="420"
                                            HorizontalAlignment="Left">

                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="White"
                                                   FontSize="15"
                                                   TextWrapping="Wrap"/>

                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>
                    <Border Grid.Row="2"
                            Background="#10182B"
                            Padding="14"
                            BorderBrush="#1A2744"
                            BorderThickness="0,1,0,0">
                        <Grid ColumnDefinitions="*,90"
                              ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding MessageToSend}"
                                     Watermark="Type a message..."
                                     Background="#0B1020"
                                     Foreground="White"
                                     BorderBrush="#274B7A"
                                     CornerRadius="10"
                                     Padding="12"/>
                            <Button Grid.Column="1"
                                    Content="Send"
                                    Command="{Binding SendMessageCommand}"
                                    Background="#274B7A"
                                    Foreground="White"
                                    CornerRadius="10"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <Border IsVisible="{Binding Is_invite_open}"
        Background="#0F172A" Width="300"
        HorizontalAlignment="Right" VerticalAlignment="Stretch"
        BorderBrush="#1A2744" BorderThickness="1,0,0,0">
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Grid Grid.Row="0" Margin="16,16,16,12" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Add a friend"
                       FontSize="15" FontWeight="Bold" Foreground="#E2E8F0"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✕"
                    Command="{Binding close_inviteCommand}"
                    Background="Transparent" Foreground="#64748B"
                    Width="28" Height="28" Padding="0"/>
        </Grid>
        <StackPanel Grid.Row="1" Margin="16,0,16,16" Spacing="8">
            <TextBox PlaceholderText="@username"
                     Text="{Binding InviteUsername}"
                     Background="#0D1829"
                     BorderBrush="#1A2744"
                     CornerRadius="8"
                     Padding="12,10"
                     Foreground="White"/>
            <Button Content="Send invite"
                    Command="{Binding SendInviteCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Background="#6366F1"
                    Foreground="White"
                    CornerRadius="8"
                    Padding="0,10"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="16,0,16,10" Spacing="10">
            <Border Height="1" Background="#1A2744"/>
            <TextBlock Text="Pending invites"
                       FontSize="12" Foreground="#64748B"/>
        </StackPanel>
<!-- the fuckass invite lits-->
        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{Binding PendingInvites}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:user">
                        <Border Padding="16,8" BorderBrush="#1A2744"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding username}"
                                           Foreground="#E2E8F0"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="✓"
                                        Command="{Binding $parent[UserControl].((vm:MainMenuViewModel)DataContext).AcceptInviteCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#14532D"
                                        Foreground="#86EFAC"
                                        CornerRadius="6"
                                        Width="30" Height="30"
                                        Padding="0"
                                        FontSize="14"/>
                                <Button Grid.Column="2"
                                        Content="✕"
                                        Command="{Binding $parent[UserControl].((vm:MainMenuViewModel)DataContext).RefuseInviteCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#450A0A"
                                        Foreground="#FCA5A5"
                                        CornerRadius="6"
                                        Width="30" Height="30"
                                        Padding="0"
                                        FontSize="14"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Border>
        <Border IsVisible="{Binding Is_setting_open}"
                Background="#88000000">  
            <Border Background="#1E293B" Width="480" Height="380"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="0">
                <!-- hold on i ll add ts later ,and avalonia stop messing with my fucking comments why u got my ass talking like a british 90s man...-->
            </Border>
        </Border>
        </Grid>
</UserControl>