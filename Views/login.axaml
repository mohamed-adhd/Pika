<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.LoginView"
    x:DataType="vm:LoginViewModel">
    <Grid>
        <TextBlock IsVisible="{Binding !Found}" Text="nigga u fucked up"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>
        <TextBlock Text="LOGIN PAGE"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"/>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
    <TextBox Text="{Binding Username}" Background="DarkGray" HorizontalAlignment="Center" VerticalAlignment="Center" PlaceholderText="username"></TextBox>
    <TextBox Text="{Binding Password}" Background="DarkGray"  HorizontalAlignment="Center" VerticalAlignment="Center" PlaceholderText="password"></TextBox> 
    <Button Content="go to register" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding GoToRegisterCommand}"></Button>
    <Button Content="login" HorizontalAlignment="Center" VerticalAlignment="Center" Command="{Binding CheckLoginCommand}"></Button>
    </StackPanel>
    
    </Grid>
    
</UserControl>