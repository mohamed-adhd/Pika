<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.LoginView"
    x:DataType="vm:LoginViewModel">
    <StackPanel>
    <TextBlock Text="LOGIN PAGE"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
    
    
    <Button Content="go to register" Command="{Binding GoToRegisterCommand}"></Button>
    
    
    </StackPanel>
</UserControl>